# ─────────────────────────────────────────────
# Telegram Vision Bot — Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# REQUIRED: Get from https://t.me/BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Vision Model Selection
# true  = nlpconnect/vit-gpt2-image-captioning (~300MB, CPU-friendly, fast)
# false = BLIP-2 or LLaVA (requires GPU, better quality)
USE_LIGHTWEIGHT_MODEL=true

# Model name when USE_LIGHTWEIGHT_MODEL=false
# Options:
#   Salesforce/blip2-opt-2.7b      (~6GB, good quality)
#   Salesforce/blip2-flan-t5-xl    (~4GB, strong VQA)
#   llava-hf/llava-1.5-7b-hf       (~14GB, best quality, GPU required)
VISION_MODEL=Salesforce/blip2-opt-2.7b

# Gradio Debug UI
GRADIO_PORT=7860
GRADIO_HOST=0.0.0.0

# Logging
LOG_LEVEL=INFO
